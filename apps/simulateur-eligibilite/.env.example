# Copier ce fichier en `.env` (gitignoré). Les variables `VITE_*` sont lues au build
# (bundlées dans le front) ; les autres sont détenues par le serveur (jamais exposées
# au front). Voir la section « Configuration » du README.

# --- Backend référentiel + contexte (voir docs/architecture/identification.md) ---

# GRIST_API_KEY — serveur, requis en prod.
# Clé API Grist, source du référentiel (établissements/services/prescripteurs).
# Jamais exposée au front. Absente ⇒ référentiel snapshot factice (dev/CI).
GRIST_API_KEY=

# GRIST_DOC_URL — serveur, optionnel.
# Base API du doc Grist. Défaut = doc du projet (voir server/referentiel.ts).
# GRIST_DOC_URL=https://grist.numerique.gouv.fr/o/transports-sanitaires/api/docs/gbPomRAyU3M6P5NR6x6Qac

# PSEUDONYMISATION_SECRET — serveur, requis en prod.
# Secret HMAC pseudonymisant le contexte prescripteur envoyé à Matomo.
# Dédié (≠ GRIST_API_KEY). Absent ⇒ secret de dev non sécurisé.
# Générer p. ex. : openssl rand -hex 32
PSEUDONYMISATION_SECRET=

# PSEUDONYMISATION_EN_CLAIR — serveur, optionnel (défaut : HMAC pseudonymisé).
# Debug : renvoie les refs prescripteur en clair (valeur préfixée) au lieu du HMAC,
# pour les lire directement dans Matomo. ⚠️ Révèle nom/prénom bruts — JAMAIS en prod.
PSEUDONYMISATION_EN_CLAIR=true

# --- Analytics Matomo (voir docs/architecture/analytics.md) ---

# VITE_MATOMO_ENABLED — front, optionnel (défaut : false, traceur no-op).
# Actif d'office en build de prod ; mettre à true pour tester le tracking en local.
VITE_MATOMO_ENABLED=false

# VITE_MATOMO_URL — front, optionnel. Défaut : instance mutualisée beta.gouv.
# VITE_MATOMO_URL=https://stats.beta.gouv.fr/

# VITE_MATOMO_SITE_ID — front, optionnel. Défaut : 275.
# VITE_MATOMO_SITE_ID=275
