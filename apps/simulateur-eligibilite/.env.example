# --- Analytics Matomo (voir docs/architecture/analytics.md) ---
# Le tracking n'est actif qu'en build de prod. Pour le tester en local, mettre
# VITE_MATOMO_ENABLED=true (sinon le traceur est un no-op).
# VITE_MATOMO_ENABLED=true

# Instance et site Matomo. Défauts : instance mutualisée beta.gouv, site 275.
# VITE_MATOMO_URL=https://stats.beta.gouv.fr/
# VITE_MATOMO_SITE_ID=275
