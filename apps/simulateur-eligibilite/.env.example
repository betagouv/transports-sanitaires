# --- Backend référentiel + contexte (voir docs/architecture/identification.md) ---
# Clé API Grist, détenue par le serveur uniquement (jamais exposée au front).
# Sans elle, le backend sert le référentiel snapshot factice (dev/fallback).
GRIST_API_KEY=
# Base API du doc Grist (optionnel : défaut = doc du projet, voir server/referentiel.ts).
# GRIST_DOC_URL=https://grist.numerique.gouv.fr/o/transports-sanitaires/api/docs/gbPomRAyU3M6P5NR6x6Qac

# Secret de pseudonymisation (HMAC) du contexte prescripteur transmis à Matomo.
# **Dédié** (≠ GRIST_API_KEY). Sans lui, un secret de dev non sécurisé est utilisé.
# Générer p. ex. : openssl rand -hex 32
PSEUDONYMISATION_SECRET=

# Debug (phase de test) : renvoie les refs prescripteur en clair (valeur préfixée)
# au lieu du HMAC, pour les lire directement dans Matomo. ⚠️ Révèle des données
# brutes (dont nom/prénom) — à n'activer JAMAIS en production.
# PSEUDONYMISATION_EN_CLAIR=true

# --- Analytics Matomo (voir docs/architecture/analytics.md) ---
# Le tracking n'est actif qu'en build de prod. Pour le tester en local, mettre
# VITE_MATOMO_ENABLED=true (sinon le traceur est un no-op).
# VITE_MATOMO_ENABLED=true

# Instance et site Matomo. Défauts : instance mutualisée beta.gouv, site 275.
# VITE_MATOMO_URL=https://stats.beta.gouv.fr/
# VITE_MATOMO_SITE_ID=275
