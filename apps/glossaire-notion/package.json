{
  "name": "glossaire-notion",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "watch": "vite build --watch",
    "test": "vitest run",
    "prezip": "npm run build",
    "zip": "rm -f glossaire-notion.zip && cd dist && zip -r ../glossaire-notion.zip . && cd .."
  },
  "dependencies": {
    "notion-client": "^7.10.0",
    "notion-types": "^7.10.0",
    "notion-utils": "^7.10.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "^20.10.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.9"
  }
}
