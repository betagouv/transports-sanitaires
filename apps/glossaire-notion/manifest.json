{
  "manifest_version": 3,
  "name": "Glossaire transports sanitaires",
  "description": "Recherche dans le glossaire des transports sanitaires hébergé sur Notion.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["https://www.notion.so/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "glossaire-notion@transports-sanitaires",
      "strict_min_version": "109.0"
    }
  }
}
